                end: Alignment.bottomCenter,
                colors: [K.navy, K.ink],
              ),
            ),
          ),
        ),
        Positioned.fill(
          child: CustomPaint(painter: BeamPainter(K.violet, 0.6)),
        ),
        SafeArea(
          child: Center(
            child: Column(
              mainAxisAlignment: MainAxisAlignment.center,
              children: [
                AnimatedBuilder(
                  animation: _pulse,
                  builder: (_, __) => Transform.scale(
                    scale: 0.9 + 0.1 * _pulse.value,
                    child: const Text('⚔️', style: TextStyle(fontSize: 100)),
                  ),
                ),
                const SizedBox(height: 24),
                Text(
