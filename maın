class LeaderboardScreen extends StatefulWidget {
  const LeaderboardScreen({super.key});
  @override
  State<LeaderboardScreen> createState() => _LeaderboardScreenState();
}

class _LeaderboardScreenState extends State<LeaderboardScreen> {
  List<Map<String, dynamic>> _board = [];
  bool _loading = true;
  int _myRank = -1;
  @override
  void initState() {
    super.initState();
    _load();
  }

  Future<void> _load() async {
    setState(() => _loading = true);
    final board = await FirebaseService.getLeaderboard();
    final rank = await FirebaseService.getMyRank();
    if (mounted)
      setState(() {
        _board = board;
        _myRank = rank;
        _loading = false;
      });
  }

  @override
  Widget build(BuildContext context) => RefreshIndicator(
    onRefresh: _load,
    color: K.gold2,
    child: _loading
        ? const Center(child: CircularProgressIndicator(color: K.gold2))
        : ListView.builder(
            padding: const EdgeInsets.all(16),
            itemCount: _board.length + 1,
            itemBuilder: (ctx, i) {
              if (i == 0) return _header();
              return _row(_board[i - 1], i);
            },
          ),
  );

  Widget _header() => Column(
    children: [
      const SizedBox(height: 8),
      GoldText(
        L10n.t('world_rank'),
        style: const TextStyle(
          fontSize: 22,
          fontWeight: FontWeight.w900,
          letterSpacing: 2,
        ),
      ),
      const SizedBox(height: 8),
      if (_myRank > 0)
        Container(
          padding: const EdgeInsets.symmetric(horizontal: 20, vertical: 8),
          decoration: BoxDecoration(
            color: K.gold2.withOpacity(0.1),
            borderRadius: BorderRadius.circular(20),
            border: Border.all(color: K.gold2.withOpacity(0.3)),
          ),
          child: Text(
            '${L10n.t('my_rank')}: #$_myRank',
            style: const TextStyle(
              color: K.gold1,
              fontWeight: FontWeight.w700,
              fontSize: 14,
            ),
          ),
        ),
      const SizedBox(height: 16),
      if (_board.length >= 3) _podium(),
      const SizedBox(height: 8),
    ],
  );

  Widget _podium() => Row(
    mainAxisAlignment: MainAxisAlignment.center,
    crossAxisAlignment: CrossAxisAlignment.end,
    children: [
      _podiumItem(_board[1], '🥈', 90),
      const SizedBox(width: 8),
      _podiumItem(_board[0], '🥇', 115),
      const SizedBox(width: 8),
      _podiumItem(_board[2], '🥉', 70),
    ],
  );

  Widget _podiumItem(Map p, String medal, double h) {
    final xp = (p['xp'] ?? 0) as int;
