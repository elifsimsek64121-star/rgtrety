//  FIREBASE SERVICE
// ═══════════════════════════════════════════════════════════════════
class FirebaseService {
  static final _auth = FirebaseAuth.instance;
  static final _db = FirebaseFirestore.instance;
  static final _google = GoogleSignIn();

  static User? get user => _auth.currentUser;
  static String? get uid => user?.uid;
  static bool get isGuest => user?.isAnonymous ?? false;

  // ── Google ──
  static Future<User?> signInWithGoogle() async {
    try {
      final acc = await _google.signIn();
      if (acc == null) return null;
      final g = await acc.authentication;
      final cred = GoogleAuthProvider.credential(
        accessToken: g.accessToken,
        idToken: g.idToken,
      );
      final r = await _auth.signInWithCredential(cred);
      await _ensureProfile(r.user);
      return r.user;
    } catch (e) {
      debugPrint('Google: $e');
      return null;
    }
  }

  // ── Facebook ──
  static Future<User?> signInWithFacebook() async {
    try {
      final result = await FacebookAuth.instance.login();
      if (result.status != LoginStatus.success) return null;
      final cred = FacebookAuthProvider.credential(
        result.accessToken!.tokenString,
      );
      final r = await _auth.signInWithCredential(cred);
      await _ensureProfile(r.user);
      return r.user;
    } catch (e) {
      debugPrint('Facebook: $e');
      return null;
    }
  }

  // ── Guest (Anonymous) ──
  static Future<User?> signInAsGuest() async {
    try {
      final r = await _auth.signInAnonymously();
      await _ensureProfile(r.user, displayName: L10n.t('guest_name'));
      return r.user;
    } catch (e) {
      debugPrint('Guest: $e');
      return null;
    }
  }

  // ── Email ──
  static Future<User?> signInWithEmail(String email, String pass) async {
    try {
      final r = await _auth.signInWithEmailAndPassword(
        email: email,
        password: pass,
      );
      await _ensureProfile(r.user);
      return r.user;
    } catch (e) {
      debugPrint('Email login: $e');
      return null;
    }
  }

  static Future<User?> registerWithEmail(
    String email,
    String pass,
    String name,
  ) async {
    try {
      final r = await _auth.createUserWithEmailAndPassword(
        email: email,
        password: pass,
      );
      await r.user?.updateDisplayName(name);
      await _ensureProfile(r.user, displayName: name);
      return r.user;
    } catch (e) {
      debugPrint('Register: $e');
      return null;
    }
  }

  // ── Sign Out ──
  static Future<void> signOut() async {
    await _google.signOut().catchError((_) {});
    await FacebookAuth.instance.logOut().catchError((_) {});
    await _auth.signOut();
  }

  // ── Profile ──
  static Future<void> _ensureProfile(User? u, {String? displayName}) async {
    if (u == null) return;
    final ref = _db.collection('users').doc(u.uid);
    final snap = await ref.get();
    if (!snap.exists) {
      await ref.set({
        'uid': u.uid,
        'name': displayName ?? u.displayName ?? L10n.t('guest_name'),
        'email': u.email ?? '',
        'photoUrl': u.photoURL ?? '',
        'xp': 0,
        'totalCorrect': 0,
        'totalGames': 0,
        'duelsWon': 0,
        'duelsLost': 0,
        'bestPrize': '0',
        'streak': 0,
        'lastLogin': FieldValue.serverTimestamp(),
        'createdAt': FieldValue.serverTimestamp(),
        'badges': <String>[],
        'aiQuestionsGenerated': 0,
        'isGuest': u.isAnonymous,
        'lang': L10n.lang,
      });
    } else {
      await ref.update({'lastLogin': FieldValue.serverTimestamp()});
    }
  }

  static Future<Map<String, dynamic>?> getProfile() async {
    if (uid == null) return null;
    final snap = await _db.collection('users').doc(uid).get();
    return snap.data();
  }

  static Future<void> updateStats({
    required int xpGain,
    required int correctCount,
    required String bestPrize,
  }) async {
    if (uid == null) return;
    final ref = _db.collection('users').doc(uid!);
    await ref.update({
      'xp': FieldValue.increment(xpGain),
      'totalCorrect': FieldValue.increment(correctCount),
      'totalGames': FieldValue.increment(1),
    });
    final snap = await ref.get();
    final data = snap.data() ?? {};
    final currentBest =
        int.tryParse(
          (data['bestPrize'] ?? '0').toString().replaceAll(
            RegExp(r'[^0-9]'),
            '',
          ),
        ) ??
        0;
    final newBest =
        int.tryParse(bestPrize.replaceAll(RegExp(r'[^0-9]'), '')) ?? 0;
    if (newBest > currentBest) await ref.update({'bestPrize': bestPrize});
    await _checkBadges();
  }

  static Future<void> _checkBadges() async {
    if (uid == null) return;
    final snap = await _db.collection('users').doc(uid!).get();
    final data = snap.data() ?? {};
    final xp = (data['xp'] ?? 0) as int;
    final correct = (data['totalCorrect'] ?? 0) as int;
    final badges = List<String>.from(data['badges'] ?? []);
    bool changed = false;
    void maybe(String b, bool c) {
      if (c && !badges.contains(b)) {
        badges.add(b);
        changed = true;
      }
    }

    maybe('first_game', true);
    maybe('xp_500', xp >= 500);
    maybe('xp_1500', xp >= 1500);
    maybe('xp_4000', xp >= 4000);
    maybe('xp_9000', xp >= 9000);
    maybe('correct_50', correct >= 50);
    maybe('correct_200', correct >= 200);
    if (changed)
      await _db.collection('users').doc(uid!).update({'badges': badges});
  }

  // ── Daily Reward ──
  static Future<Map<String, dynamic>> claimDailyReward() async {
    if (uid == null || isGuest) return {'claimed': false};
    final ref = _db.collection('users').doc(uid!);
    final snap = await ref.get();
    final data = snap.data() ?? {};
    final last = (data['lastRewardDate'] as Timestamp?)?.toDate();
    final today = DateTime.now();
    final streak = (data['streak'] ?? 0) as int;
    if (last != null &&
        last.year == today.year &&
        last.month == today.month &&
        last.day == today.day) {
      return {'claimed': false, 'streak': streak};
    }
    final newStreak = (last != null && today.difference(last).inDays == 1)
        ? streak + 1
        : 1;
    final reward = newStreak >= 30
        ? 300
        : newStreak >= 14
        ? 200
        : newStreak >= 7
        ? 150
        : newStreak >= 3
        ? 100
        : 50;
    await ref.update({
      'lastRewardDate': FieldValue.serverTimestamp(),
      'streak': newStreak,
      'xp': FieldValue.increment(reward),
    });
    return {'claimed': true, 'streak': newStreak, 'xp': reward};
  }

  // ── Leaderboard ──
  static Future<List<Map<String, dynamic>>> getLeaderboard({
    int limit = 50,
  }) async {
    final snap = await _db
        .collection('users')
        .orderBy('xp', descending: true)
        .limit(limit)
        .get();
    return snap.docs.map((d) => {...d.data(), 'uid': d.id}).toList();
  }

  static Future<int> getMyRank() async {
    if (uid == null) return -1;
    final mySnap = await _db.collection('users').doc(uid!).get();
    final myXP = (mySnap.data()?['xp'] ?? 0) as int;
    final higher = await _db
        .collection('users')
        .where('xp', isGreaterThan: myXP)
        .count()
        .get();
    return (higher.count ?? 0) + 1;
  }

  // ── Duel ──
  static Future<String> createDuel(Map<String, dynamic> myData) async {
    final ref = await _db.collection('duels').add({
      'status': 'waiting',
      'createdAt': FieldValue.serverTimestamp(),
      'player1': {
        'uid': uid,
        'name': myData['name'],
        'xp': myData['xp'],
        'score': 0,
        'answers': [],
        'finished': false,
      },
      'player2': null,
      'questions': [],
      'startedAt': null,
    });
    return ref.id;
  }

  static Future<bool> joinDuel(
    String duelId,
    Map<String, dynamic> myData,
  ) async {
    try {
      await _db.collection('duels').doc(duelId).update({
        'status': 'starting',
        'player2': {
          'uid': uid,
          'name': myData['name'],
          'xp': myData['xp'],
          'score': 0,
          'answers': [],
          'finished': false,
        },
      });
      return true;
    } catch (e) {
      return false;
    }
  }

  static Stream<DocumentSnapshot> duelStream(String duelId) =>
      _db.collection('duels').doc(duelId).snapshots();

  static Future<void> updateDuelAnswer({
    required String duelId,
    required String player,
    required int questionIdx,
    required int answerIdx,
    required bool correct,
    required int timeMs,
  }) async {
    final points = correct ? (1000 - timeMs ~/ 10).clamp(100, 1000) : 0;
    await _db.collection('duels').doc(duelId).update({
      '$player.answers': FieldValue.arrayUnion([
        {
          'q': questionIdx,
          'a': answerIdx,
          'correct': correct,
          'points': points,
        },
      ]),
      '$player.score': FieldValue.increment(points),
    });
  }

  static Future<void> finishDuel(String duelId, String player) async {
    await _db.collection('duels').doc(duelId).update({
      '$player.finished': true,
    });
  }

  static Future<List<Map<String, dynamic>>> findOpenDuels() async {
    final snap = await _db
        .collection('duels')
        .where('status', isEqualTo: 'waiting')
        .orderBy('createdAt', descending: true)
        .limit(20)
        .get();
    return snap.docs
        .where((d) => d.data()['player1']['uid'] != uid)
        .map((d) => {...d.data(), 'id': d.id})
        .toList();
  }

  static Future<void> setDuelQuestions(
    String duelId,
    List<Map<String, dynamic>> qs,
  ) async {
    await _db.collection('duels').doc(duelId).update({
      'questions': qs,
      'status': 'active',
      'startedAt': FieldValue.serverTimestamp(),
    });
  }

  static Future<void> updateDuelResult(String duelId, String winnerUid) async {
    if (uid == null) return;
    await _db.collection('duels').doc(duelId).update({
      'status': 'finished',
      'winnerUid': winnerUid,
      'finishedAt': FieldValue.serverTimestamp(),
    });
    final isWinner = winnerUid == uid;
    await _db.collection('users').doc(uid!).update({
      if (isWinner) 'duelsWon': FieldValue.increment(1),
      if (!isWinner) 'duelsLost': FieldValue.increment(1),
      'xp': FieldValue.increment(isWinner ? 150 : 30),
    });
  }
}

