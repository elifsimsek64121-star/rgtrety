//  DUEL GAME SCREEN
// ═══════════════════════════════════════════════════════════════════
class DuelGameScreen extends StatefulWidget {
  final String duelId;
  final Map<String, dynamic> duelData;
  final Map<String, dynamic> profile;
  const DuelGameScreen({
    super.key,
    required this.duelId,
    required this.duelData,
    required this.profile,
  });
  @override
  State<DuelGameScreen> createState() => _DuelGameScreenState();
}

class _DuelGameScreenState extends State<DuelGameScreen>
    with TickerProviderStateMixin {
  late List<Map<String, dynamic>> _questions;
  int _qIdx = 0, _selected = -1, _timeLeft = 15, _myScore = 0, _oppScore = 0;
  bool _answered = false, _finished = false;
  StreamSubscription? _sub;
  late final AnimationController _timer = AnimationController(
    vsync: this,
    duration: const Duration(seconds: 15),
  );
  late final AnimationController _ambient = AnimationController(
    vsync: this,
    duration: const Duration(seconds: 3),
  )..repeat(reverse: true);
  late final Animation<double> _glow = Tween(
    begin: 0.5,
    end: 1.0,
  ).animate(_ambient);
  DateTime? _questionStart;

  String get _myKey => widget.duelData['player1']['uid'] == FirebaseService.uid
      ? 'player1'
      : 'player2';
  String get _oppKey => _myKey == 'player1' ? 'player2' : 'player1';

  @override
  void initState() {
    super.initState();
    _questions = (widget.duelData['questions'] as List)
        .cast<Map<String, dynamic>>();
    _sub = FirebaseService.duelStream(widget.duelId).listen(_onUpdate);
    _startTimer();
  }

  @override
  void dispose() {
    _timer.dispose();
    _ambient.dispose();
    _sub?.cancel();
    super.dispose();
  }

  void _onUpdate(DocumentSnapshot snap) {
    if (!snap.exists || !mounted) return;
    final data = snap.data() as Map<String, dynamic>;
    final opp = data[_oppKey] as Map?;
    if (opp != null) setState(() => _oppScore = (opp['score'] ?? 0) as int);
    final p1 = data['player1'] as Map?;
    final p2 = data['player2'] as Map?;
    if ((p1?['finished'] == true) &&
        (p2?['finished'] == true) &&
        !_finished &&
        mounted) {
      _finished = true;
      final myScore = (data[_myKey]?['score'] ?? 0) as int;
      final oppScore = (data[_oppKey]?['score'] ?? 0) as int;
      final winnerUid = myScore >= oppScore
          ? FirebaseService.uid!
          : (data[_oppKey]?['uid'] as String? ?? '');
      FirebaseService.updateDuelResult(widget.duelId, winnerUid);
      Future.delayed(const Duration(milliseconds: 400), () {
        if (mounted) _showResult(myScore, oppScore);
      });
    }
  }

  void _startTimer() {
    _questionStart = DateTime.now();
    _timeLeft = 15;
    _timer.duration = const Duration(seconds: 15);
    _timer.forward(from: 0);
    _timer.addStatusListener((s) {
      if (s == AnimationStatus.completed && !_answered) _answer(-1);
    });
    _timer.addListener(() {
      final n = 15 - (_timer.lastElapsedDuration?.inSeconds ?? 0);
      if (n != _timeLeft && mounted) setState(() => _timeLeft = n.clamp(0, 15));
    });
  }

  Future<void> _answer(int idx) async {
    if (_answered) return;
    _timer.stop();
    final timeMs = DateTime.now().difference(_questionStart!).inMilliseconds;
    final q = _questions[_qIdx];
    final opts = (q['options'] as List).cast<String>();
    final corrIdx = opts.indexOf(q['correctAnswer']?.toString() ?? '');
    final isCorrect = idx == corrIdx && idx >= 0;
    setState(() {
      _selected = idx;
      _answered = true;
    });
    await FirebaseService.updateDuelAnswer(
      duelId: widget.duelId,
      player: _myKey,
      questionIdx: _qIdx,
      answerIdx: idx,
      correct: isCorrect,
      timeMs: timeMs,
    );
    if (isCorrect)
      setState(() => _myScore += (1000 - timeMs ~/ 10).clamp(100, 1000));
    await Future.delayed(const Duration(milliseconds: 1200));
    if (_qIdx < _questions.length - 1) {
      setState(() {
        _qIdx++;
        _selected = -1;
        _answered = false;
      });
      _startTimer();
    } else {
      await FirebaseService.finishDuel(widget.duelId, _myKey);
    }
  }

  void _showResult(int my, int opp) {
    final win = my > opp;
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (_) => _glassDlg(
        borderColor: win ? K.correct : K.wrong,
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            Text(win ? '🏆' : '💔', style: const TextStyle(fontSize: 72)),
            const SizedBox(height: 12),
            Text(
              win ? L10n.t('won') : L10n.t('lost'),
              style: TextStyle(
                fontSize: 28,
                fontWeight: FontWeight.w900,
                color: win ? K.correct : K.wrong,
                letterSpacing: 2,
              ),
            ),
            const SizedBox(height: 16),
            Row(
              mainAxisAlignment: MainAxisAlignment.spaceEvenly,
              children: [
                _scoreBox(L10n.t('me'), my, win ? K.correct : K.w60),
                const Text('vs', style: TextStyle(color: K.w40, fontSize: 18)),
                _scoreBox(L10n.t('opponent'), opp, !win ? K.correct : K.w60),
              ],
            ),
            const SizedBox(height: 8),
            Text(
              win ? L10n.t('xp_win') : L10n.t('xp_lose'),
              style: const TextStyle(color: K.w60, fontSize: 13),
            ),
            const SizedBox(height: 20),
            _goldBtn(L10n.t('ok'), () {
              Navigator.pop(context);
              Navigator.pop(context);
            }),
          ],
        ),
      ),
    );
  }

  Widget _scoreBox(String label, int score, Color c) => Column(
    children: [
      Text(
        '$score',
        style: TextStyle(color: c, fontSize: 32, fontWeight: FontWeight.w900),
      ),
      Text(label, style: const TextStyle(color: K.w40, fontSize: 12)),
    ],
  );

  @override
  Widget build(BuildContext context) {
    if (_questions.isEmpty)
      return const Scaffold(
        body: Center(child: CircularProgressIndicator(color: K.gold2)),
      );
    final q = _questions[_qIdx];
    final opts = (q['options'] as List).cast<String>();
    final corrIdx = opts.indexOf(q['correctAnswer']?.toString() ?? '');
    final landscape =
        MediaQuery.of(context).size.width > MediaQuery.of(context).size.height;
    return Scaffold(
      body: AnimatedBuilder(
        animation: _ambient,
        builder: (_, __) => Stack(
          children: [
            Positioned.fill(
              child: Container(
                decoration: const BoxDecoration(
                  gradient: LinearGradient(
                    begin: Alignment.topCenter,
                    end: Alignment.bottomCenter,
                    colors: [K.navy, K.ink],
                  ),
                ),
              ),
            ),
            Positioned.fill(
              child: CustomPaint(
                painter: BeamPainter(K.violet, 0.4 * _glow.value),
              ),
            ),
            Positioned.fill(child: CustomPaint(painter: ScanlinePainter(1.0))),
            SafeArea(
              child: landscape
                  ? _landscape(q, opts, corrIdx)
                  : _portrait(q, opts, corrIdx),
            ),
          ],
        ),
      ),
    );
  }

  Widget _portrait(Map q, List<String> opts, int ci) => Column(
    children: [
      _header(),
      Expanded(
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(14),
          child: Column(
            children: [
              _qCard(q),
              const SizedBox(height: 12),
              ...List.generate(opts.length, (i) => _optWidget(i, opts[i], ci)),
            ],
          ),
        ),
      ),
    ],
  );

  Widget _landscape(Map q, List<String> opts, int ci) => Row(
    children: [
      Expanded(
        flex: 2,
        child: Column(
          children: [
            _header(),
            Expanded(
              child: Padding(
                padding: const EdgeInsets.all(14),
                child: _qCard(q),
              ),
            ),
          ],
        ),
      ),
      Expanded(
        flex: 3,
        child: SingleChildScrollView(
          padding: const EdgeInsets.all(14),
          child: Column(
            children: [
              ...List.generate(opts.length, (i) => _optWidget(i, opts[i], ci)),
            ],
          ),
        ),
      ),
    ],
  );

  Widget _header() => Container(
    padding: const EdgeInsets.symmetric(horizontal: 16, vertical: 10),
    color: K.panel.withOpacity(0.9),
    child: Row(
      children: [
        _playerScore(L10n.t('me'), _myScore, K.violet),
        Expanded(
          child: Column(
            children: [
              Text(
                '${_qIdx + 1}/${_questions.length}',
                style: const TextStyle(color: K.w60, fontSize: 11),
              ),
              const SizedBox(height: 4),
              SizedBox(
                width: 60,
                height: 60,
                child: Stack(
                  alignment: Alignment.center,
                  children: [
                    CircularProgressIndicator(
                      value: _timeLeft / 15.0,
                      color: _timeLeft > 8 ? K.correct : K.wrong,
                      backgroundColor: K.w10,
                      strokeWidth: 4,
                    ),
                    Text(
                      '$_timeLeft',
                      style: TextStyle(
                        color: _timeLeft > 8 ? K.correct : K.wrong,
                        fontSize: 20,
                        fontWeight: FontWeight.w900,
                      ),
                    ),
                  ],
                ),
              ),
            ],
          ),
        ),
        _playerScore(L10n.t('opponent'), _oppScore, K.cyan),
      ],
    ),
  );

  Widget _playerScore(String label, int score, Color c) => Column(
    children: [
      Text(
        label,
        style: TextStyle(color: c, fontSize: 10, fontWeight: FontWeight.w700),
      ),
      const SizedBox(height: 4),
      Text(
        '$score',
        style: TextStyle(color: c, fontSize: 22, fontWeight: FontWeight.w900),
      ),
      Text(L10n.t('score'), style: const TextStyle(color: K.w40, fontSize: 10)),
    ],
  );

  Widget _qCard(Map q) => GlassBox(
    borderColor: K.violet,
    radius: 18,
    padding: const EdgeInsets.all(20),
    child: Text(
      q['question']?.toString() ?? '',
      textAlign: TextAlign.center,
      style: const TextStyle(
        fontSize: 15,
        color: K.w100,
        fontWeight: FontWeight.w500,
        height: 1.6,
      ),
    ),
  );

  Widget _optWidget(int i, String text, int ci) {
    const letters = ['A', 'B', 'C', 'D'];
    final col = K.opts[i % 4];
    final isSel = _selected == i;
    final isCorr = ci == i;
    Color sc = col;
    bool glow = false;
    if (_answered) {
      if (isCorr) {
        sc = K.correct;
        glow = true;
      } else if (isSel) {
        sc = K.wrong;
        glow = true;
      } else
        sc = col.withOpacity(0.3);
    } else if (isSel) {
      sc = K.select;
      glow = true;
    }
    return Padding(
      padding: const EdgeInsets.only(bottom: 10),
      child: GestureDetector(
        onTap: (_answered || _selected != -1) ? null : () => _answer(i),
        child: AnimatedContainer(
          duration: const Duration(milliseconds: 250),
          padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 14),
          decoration: BoxDecoration(
            borderRadius: BorderRadius.circular(14),
            gradient: LinearGradient(
              begin: Alignment.centerLeft,
              end: Alignment.centerRight,
              colors: glow
                  ? [sc.withOpacity(0.28), sc.withOpacity(0.10)]
                  : [K.panelMid.withOpacity(0.75), K.panel.withOpacity(0.65)],
            ),
            border: Border.all(
              color: glow ? sc : col.withOpacity(_answered ? 0.15 : 0.32),
              width: glow ? 1.8 : 1,
            ),
            boxShadow: glow
                ? [BoxShadow(color: sc.withOpacity(0.42), blurRadius: 20)]
                : [],
          ),
          child: Row(
            children: [
              Container(
                width: 36,
                height: 36,
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(10),
                  gradient: LinearGradient(
                    colors: glow
                        ? [sc.withOpacity(0.5), sc.withOpacity(0.22)]
                        : [col.withOpacity(0.20), col.withOpacity(0.07)],
                  ),
                  border: Border.all(color: glow ? sc : col.withOpacity(0.40)),
                ),
                alignment: Alignment.center,
                child: Text(
                  letters[i],
                  style: TextStyle(
                    fontWeight: FontWeight.w900,
                    fontSize: 15,
                    color: glow ? sc : col,
                  ),
                ),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: Text(
                  text,
                  style: TextStyle(
                    fontSize: 14,
                    color: glow ? K.w100 : K.w80,
                    height: 1.3,
                  ),
                ),
              ),
            ],
          ),
        ),
      ),
    );
  }
}

