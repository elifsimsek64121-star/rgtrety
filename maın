  const DuelWaitingScreen({
    super.key,
    required this.duelId,
    required this.isHost,
    required this.profile,
  });
  @override
  State<DuelWaitingScreen> createState() => _DuelWaitingScreenState();
}

class _DuelWaitingScreenState extends State<DuelWaitingScreen>
    with SingleTickerProviderStateMixin {
  StreamSubscription? _sub;
  bool _starting = false;
  late final AnimationController _pulse = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 1200),
  )..repeat(reverse: true);
  @override
  void initState() {
    super.initState();
    _sub = FirebaseService.duelStream(widget.duelId).listen(_onUpdate);
  }

  @override
  void dispose() {
    _sub?.cancel();
    _pulse.dispose();
    super.dispose();
  }

  void _onUpdate(DocumentSnapshot snap) async {
    if (!snap.exists || _starting) return;
    final data = snap.data() as Map<String, dynamic>;
    final status = data['status'] as String;
    if (status == 'starting' && widget.isHost) {
      _starting = true;
      final qs = await _loadQuestions();
      if (qs.isNotEmpty)
        await FirebaseService.setDuelQuestions(widget.duelId, qs);
    }
    if (status == 'active' && mounted) {
      Navigator.pushReplacement(
        context,
        MaterialPageRoute(
          builder: (_) => DuelGameScreen(
            duelId: widget.duelId,
            duelData: data,
            profile: widget.profile,
          ),
        ),
      );
    }
  }

  Future<List<Map<String, dynamic>>> _loadQuestions() async {
    try {
      final raw =
          json.decode(await rootBundle.loadString('assets/questions.json'))
              as List;
      final qs = raw.map((e) => Map<String, dynamic>.from(e)).toList()
        ..shuffle();
      return qs.take(10).toList();
    } catch (e) {
      return [];
    }
  }

  @override
  Widget build(BuildContext context) => Scaffold(
    body: Stack(
      children: [
        Positioned.fill(
          child: Container(
            decoration: const BoxDecoration(
              gradient: LinearGradient(
