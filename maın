class League {
  final String name, emoji;
  final Color color, glow;
  final int minXP, maxXP;
  const League(
    this.name,
    this.emoji,
    this.color,
    this.glow,
    this.minXP,
    this.maxXP,
  );

  static List<League> get all => L10n.lang == 'tr' ? _allTr : _allEn;

  static const _allTr = [
    League('Bronz', '🥉', Color(0xFFCD7F32), Color(0xFFE8A96A), 0, 499),
    League('Gümüş', '🥈', Color(0xFFC0C0C0), Color(0xFFE8E8E8), 500, 1499),
    League('Altın', '🥇', Color(0xFFFFD700), Color(0xFFFFEE58), 1500, 3999),
    League('Elmas', '💎', Color(0xFF00E5FF), Color(0xFF82FFFF), 4000, 8999),
    League('Efsane', '👑', Color(0xFFD500F9), Color(0xFFEA80FF), 9000, 999999),
  ];
  static const _allEn = [
    League('Bronze', '🥉', Color(0xFFCD7F32), Color(0xFFE8A96A), 0, 499),
    League('Silver', '🥈', Color(0xFFC0C0C0), Color(0xFFE8E8E8), 500, 1499),
    League('Gold', '🥇', Color(0xFFFFD700), Color(0xFFFFEE58), 1500, 3999),
    League('Diamond', '💎', Color(0xFF00E5FF), Color(0xFF82FFFF), 4000, 8999),
    League('Legend', '👑', Color(0xFFD500F9), Color(0xFFEA80FF), 9000, 999999),
  ];

  static League forXP(int xp) {
    for (final l in all.reversed) {
      if (xp >= l.minXP) return l;
    }
    return all.first;
  }

  double progress(int xp) {
    if (maxXP == 999999) return 1.0;
    return ((xp - minXP) / (maxXP - minXP)).clamp(0.0, 1.0);
  }
}

