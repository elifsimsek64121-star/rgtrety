// ═══════════════════════════════════════════════════════════════════
//  AI GAME SCREEN
// ═══════════════════════════════════════════════════════════════════
class AIGameScreen extends StatefulWidget {
  const AIGameScreen({super.key});
  @override
  State<AIGameScreen> createState() => _AIGameScreenState();
}

class _AIGameScreenState extends State<AIGameScreen>
    with TickerProviderStateMixin {
  List<Map<String, dynamic>> _questions = [];
  bool _loading = true;
  int _qIdx = 0, _selected = -1, _score = 0, _correct = 0;
  bool _answered = false, _finished = false;
  String _topic = '', _difficulty = 'medium';

  late final AnimationController _ambient = AnimationController(
    vsync: this,
    duration: const Duration(seconds: 3),
  )..repeat(reverse: true);
  late final Animation<double> _glow = Tween(
    begin: 0.5,
    end: 1.0,
  ).animate(_ambient);

  List<String> get _topicKeys => [
    'topics_general',
    'topics_history',
    'topics_geo',
    'topics_science',
    'topics_sport',
    'topics_art',
    'topics_tech',
  ];

  @override
  void initState() {
    super.initState();
    _topic = L10n.t('topics_general');
    _showSetup();
  }

  @override
  void dispose() {
    _ambient.dispose();
    super.dispose();
  }

  void _showSetup() {
    String selTopic = _topic;
    String selDiff = _difficulty;
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (ctx) => StatefulBuilder(
        builder: (ctx, setSt) => _glassDlg(
          borderColor: K.cyan,
          child: Column(
            mainAxisSize: MainAxisSize.min,
            children: [
              const Text('🤖', style: TextStyle(fontSize: 56)),
              GoldText(
                L10n.t('ai_mode_title'),
                style: const TextStyle(
                  fontSize: 20,
                  fontWeight: FontWeight.w900,
                  letterSpacing: 2,
                ),
              ),
              const SizedBox(height: 6),
              Text(
                L10n.t('ai_sub'),
                textAlign: TextAlign.center,
                style: const TextStyle(color: K.w60, fontSize: 13),
              ),
              const SizedBox(height: 16),
              Align(
                alignment: Alignment.centerLeft,
                child: Text(
                  L10n.t('topic'),
                  style: const TextStyle(color: K.w60, fontSize: 13),
                ),
              ),
              const SizedBox(height: 6),
              Wrap(
                spacing: 6,
                runSpacing: 6,
                children: _topicKeys.map((tk) {
                  final label = L10n.t(tk);
                  return GestureDetector(
                    onTap: () => setSt(() => selTopic = label),
                    child: Container(
                      padding: const EdgeInsets.symmetric(
                        horizontal: 12,
                        vertical: 6,
                      ),
                      decoration: BoxDecoration(
                        borderRadius: BorderRadius.circular(20),
                        color: selTopic == label
                            ? K.cyan.withOpacity(0.25)
                            : K.w05,
                        border: Border.all(
                          color: selTopic == label ? K.cyan : K.w20,
                        ),
                      ),
                      child: Text(
                        label,
                        style: TextStyle(
                          color: selTopic == label ? K.cyan : K.w60,
                          fontSize: 12,
                          fontWeight: FontWeight.w600,
                        ),
                      ),
                    ),
                  );
                }).toList(),
              ),
              const SizedBox(height: 14),
              Align(
                alignment: Alignment.centerLeft,
                child: Text(
                  L10n.t('difficulty'),
                  style: const TextStyle(color: K.w60, fontSize: 13),
                ),
              ),
              const SizedBox(height: 6),
              Row(
                children: [
                  _diffBtn(
                    L10n.t('easy'),
                    'easy',
                    selDiff,
                    setSt,
                    (v) => selDiff = v,
                  ),
                  const SizedBox(width: 6),
                  _diffBtn(
                    L10n.t('medium'),
                    'medium',
                    selDiff,
                    setSt,
                    (v) => selDiff = v,
                  ),
                  const SizedBox(width: 6),
                  _diffBtn(
                    L10n.t('hard'),
                    'hard',
                    selDiff,
                    setSt,
                    (v) => selDiff = v,
                  ),
                ],
              ),
              const SizedBox(height: 20),
              Row(
                children: [
                  Expanded(
                    child: _ghostBtn(L10n.t('cancel'), () {
                      Navigator.pop(ctx);
                      Navigator.pop(context);
                    }),
                  ),
                  const SizedBox(width: 12),
                  Expanded(
                    flex: 2,
                    child: GestureDetector(
                      onTap: () {
                        Navigator.pop(ctx);
                        setState(() {
                          _topic = selTopic;
                          _difficulty = selDiff;
                        });
                        _generateQuestions();
                      },
                      child: Container(
                        padding: const EdgeInsets.symmetric(vertical: 15),
                        decoration: BoxDecoration(
                          borderRadius: BorderRadius.circular(13),
                          gradient: const LinearGradient(
                            colors: [K.cyan, K.cyanDeep],
                          ),
                          boxShadow: [
                            BoxShadow(
                              color: K.cyan.withOpacity(0.4),
                              blurRadius: 20,
                            ),
                          ],
                        ),
                        alignment: Alignment.center,
                        child: Text(
                          L10n.t('start'),
                          style: const TextStyle(
                            color: Colors.black87,
                            fontWeight: FontWeight.w900,
                            fontSize: 15,
                          ),
                        ),
                      ),
                    ),
                  ),
                ],
              ),
            ],
          ),
        ),
      ),
    );
  }

  Widget _diffBtn(
    String label,
    String code,
    String sel,
    StateSetter setSt,
    Function(String) onSel,
  ) => Expanded(
    child: GestureDetector(
      onTap: () => setSt(() => onSel(code)),
      child: Container(
        padding: const EdgeInsets.symmetric(vertical: 10),
        decoration: BoxDecoration(
          borderRadius: BorderRadius.circular(10),
          color: sel == code ? K.cyan.withOpacity(0.2) : K.w05,
          border: Border.all(color: sel == code ? K.cyan : K.w20),
        ),
        alignment: Alignment.center,
        child: Text(
          label,
          style: TextStyle(
            color: sel == code ? K.cyan : K.w60,
            fontSize: 12,
            fontWeight: FontWeight.w700,
          ),
        ),
      ),
    ),
  );

  Future<void> _generateQuestions() async {
    setState(() => _loading = true);
    final qs = await AIQuestionService.generateQuestions(
      count: 8,
      difficulty: _difficulty,
      topic: _topic,
    );
    if (qs.isEmpty) {
      try {
        final raw =
            json.decode(await rootBundle.loadString('assets/questions.json'))
                as List;
        final local = raw.map((e) => Map<String, dynamic>.from(e)).toList()
          ..shuffle();
        setState(() {
          _questions = local.take(8).toList();
          _loading = false;
        });
      } catch (e) {
        setState(() => _loading = false);
      }
    } else {
      setState(() {
        _questions = qs;
        _loading = false;
      });
    }
  }

  int get _corrIdx {
    if (_qIdx >= _questions.length) return -1;
    final q = _questions[_qIdx];
    final opts = (q['options'] as List?)?.cast<String>() ?? [];
    return opts.indexOf(q['correctAnswer']?.toString() ?? '');
  }

  void _select(int i) async {
    if (_answered) return;
    setState(() {
      _selected = i;
      _answered = true;
    });
    if (i == _corrIdx)
      setState(() {
        _score += 100;
        _correct++;
      });
    await Future.delayed(const Duration(milliseconds: 1400));
    if (_qIdx < _questions.length - 1) {
      setState(() {
        _qIdx++;
        _selected = -1;
        _answered = false;
      });
    } else {
      setState(() => _finished = true);
      await FirebaseService.updateStats(
        xpGain: _correct * 15,
        correctCount: _correct,
        bestPrize: '0',
      );
      _showResult();
    }
  }

  void _showResult() => showDialog(
    context: context,
    barrierDismissible: false,
    builder: (_) => _glassDlg(
      borderColor: K.cyan,
      child: Column(
        mainAxisSize: MainAxisSize.min,
        children: [
          const Text('🤖', style: TextStyle(fontSize: 56)),
          GoldText(
            L10n.t('result'),
            style: const TextStyle(
              fontSize: 24,
              fontWeight: FontWeight.w900,
              letterSpacing: 2,
            ),
          ),
          const SizedBox(height: 14),
          Text(
            '$_correct/${_questions.length} ${L10n.t('correct')}',
            style: const TextStyle(
              color: K.w80,
              fontSize: 20,
              fontWeight: FontWeight.w700,
            ),
          ),
          Text(
            '+${_correct * 15} XP',
            style: const TextStyle(
              color: K.gold2,
              fontSize: 16,
              fontWeight: FontWeight.w700,
            ),
          ),
          const SizedBox(height: 20),
          Row(
            children: [
              Expanded(
                child: _ghostBtn(L10n.t('exit'), () {
                  Navigator.pop(context);
                  Navigator.pop(context);
                }),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: _goldBtn(L10n.t('play_again'), () {
                  Navigator.pop(context);
                  setState(() {
                    _qIdx = 0;
                    _selected = -1;
                    _score = 0;
                    _correct = 0;
                    _answered = false;
                    _finished = false;
                  });
                  _showSetup();
                }),
              ),
            ],
          ),
        ],
      ),
    ),
  );

  @override
  Widget build(BuildContext context) => Scaffold(
    body: AnimatedBuilder(
      animation: _ambient,
      builder: (_, __) => Stack(
        children: [
          Positioned.fill(
            child: Container(
              decoration: const BoxDecoration(
                gradient: LinearGradient(
                  begin: Alignment.topCenter,
                  end: Alignment.bottomCenter,
                  colors: [K.navy, K.ink],
                ),
              ),
            ),
          ),
          Positioned.fill(
            child: CustomPaint(painter: BeamPainter(K.cyan, 0.4 * _glow.value)),
          ),
          Positioned.fill(child: CustomPaint(painter: ScanlinePainter(1.0))),
          SafeArea(child: _loading ? _loadingView() : _gameView()),
        ],
      ),
    ),
  );

  Widget _loadingView() => Center(
    child: Column(
      mainAxisSize: MainAxisSize.min,
      children: [
        const Text('🤖', style: TextStyle(fontSize: 72)),
        const SizedBox(height: 20),
        ShaderMask(
          shaderCallback: (b) =>
              const LinearGradient(colors: [K.cyan, K.blue]).createShader(b),
          child: Text(
            L10n.t('generating'),
            style: const TextStyle(
              color: Colors.white,
              fontSize: 17,
              fontWeight: FontWeight.w700,
            ),
          ),
        ),
        const SizedBox(height: 10),
        Text(
          L10n.t('gen_wait'),
          style: const TextStyle(color: K.w40, fontSize: 13),
        ),
        const SizedBox(height: 20),
        SizedBox(
          width: 200,
          child: LinearProgressIndicator(
            backgroundColor: K.w10,
            valueColor: const AlwaysStoppedAnimation(K.cyan),
            minHeight: 3,
            borderRadius: BorderRadius.circular(2),
          ),
        ),
      ],
    ),
  );

  Widget _gameView() {
    if (_questions.isEmpty)
      return Center(
        child: Column(
          mainAxisSize: MainAxisSize.min,
          children: [
            const Text('❌', style: TextStyle(fontSize: 56)),
            const SizedBox(height: 14),
            Text(
              L10n.t('no_questions'),
              style: const TextStyle(color: K.w60, fontSize: 17),
            ),
            const SizedBox(height: 14),
            _goldBtn(L10n.t('back'), () => Navigator.pop(context)),
          ],
        ),
      );
    final q = _questions[_qIdx];
    final opts = (q['options'] as List?)?.cast<String>() ?? [];
    return Column(
      children: [
        Container(
          padding: const EdgeInsets.all(16),
          color: K.panel.withOpacity(0.9),
          child: Row(
            children: [
              GestureDetector(
                onTap: () => Navigator.pop(context),
                child: const Icon(Icons.close, color: K.w40),
              ),
              const SizedBox(width: 12),
              Expanded(
                child: Column(
                  crossAxisAlignment: CrossAxisAlignment.start,
                  children: [
                    ShaderMask(
                      shaderCallback: (b) => const LinearGradient(
                        colors: [K.cyan, K.blue],
                      ).createShader(b),
                      child: Text(
                        '🤖 AI · $_topic',
                        style: const TextStyle(
                          color: Colors.white,
                          fontSize: 11,
                          fontWeight: FontWeight.w800,
                          letterSpacing: 1.5,
                        ),
                      ),
                    ),
                    const SizedBox(height: 3),
                    ClipRRect(
                      borderRadius: BorderRadius.circular(3),
                      child: LinearProgressIndicator(
                        value: (_qIdx + 1) / _questions.length,
                        backgroundColor: K.w10,
                        valueColor: const AlwaysStoppedAnimation(K.cyan),
                        minHeight: 5,
                      ),
                    ),
                  ],
                ),
              ),
              const SizedBox(width: 12),
              Container(
                padding: const EdgeInsets.symmetric(
                  horizontal: 12,
                  vertical: 6,
                ),
                decoration: BoxDecoration(
                  color: K.cyan.withOpacity(0.15),
                  borderRadius: BorderRadius.circular(20),
                  border: Border.all(color: K.cyan.withOpacity(0.3)),
                ),
                child: Text(
                  '$_score pts',
                  style: const TextStyle(
                    color: K.cyan,
                    fontWeight: FontWeight.w800,
                    fontSize: 13,
                  ),
                ),
              ),
            ],
          ),
        ),
        Expanded(
          child: SingleChildScrollView(
            padding: const EdgeInsets.all(14),
            child: Column(
              children: [
                Container(
                  padding: const EdgeInsets.symmetric(
                    horizontal: 12,
                    vertical: 5,
                  ),
                  decoration: BoxDecoration(
                    borderRadius: BorderRadius.circular(20),
                    color: K.cyan.withOpacity(0.1),
                    border: Border.all(color: K.cyan.withOpacity(0.3)),
                  ),
                  child: Text(
                    '${L10n.t('question')} ${_qIdx + 1}/${_questions.length}',
                    style: const TextStyle(
                      color: K.cyan,
                      fontSize: 10,
                      fontWeight: FontWeight.w800,
                      letterSpacing: 2,
                    ),
                  ),
                ),
                const SizedBox(height: 14),
                GlassBox(
                  borderColor: K.cyan,
                  radius: 20,
                  padding: const EdgeInsets.all(20),
                  child: Text(
                    q['question']?.toString() ?? '',
                    textAlign: TextAlign.center,
                    style: const TextStyle(
                      fontSize: 16,
                      color: K.w100,
                      fontWeight: FontWeight.w500,
                      height: 1.65,
                    ),
                  ),
                ),
                const SizedBox(height: 14),
                ...List.generate(opts.length, (i) {
                  const letters = ['A', 'B', 'C', 'D'];
                  final col = K.opts[i % 4];
                  final isSel = _selected == i;
                  final isCorr = _corrIdx == i;
                  Color sc = col;
                  bool glow = false;
                  if (_answered) {
                    if (isCorr) {
                      sc = K.correct;
                      glow = true;
                    } else if (isSel) {
                      sc = K.wrong;
                      glow = true;
                    } else
                      sc = col.withOpacity(0.3);
                  } else if (isSel) {
                    sc = K.select;
                    glow = true;
                  }
                  return Padding(
                    padding: const EdgeInsets.only(bottom: 10),
                    child: GestureDetector(
                      onTap: (_answered || _selected != -1)
                          ? null
                          : () => _select(i),
                      child: AnimatedContainer(
                        duration: const Duration(milliseconds: 250),
                        padding: const EdgeInsets.symmetric(
                          horizontal: 14,
                          vertical: 14,
                        ),
                        decoration: BoxDecoration(
                          borderRadius: BorderRadius.circular(16),
                          gradient: LinearGradient(
                            begin: Alignment.centerLeft,
                            end: Alignment.centerRight,
                            colors: glow
                                ? [sc.withOpacity(0.28), sc.withOpacity(0.10)]
                                : [
                                    K.panelMid.withOpacity(0.75),
                                    K.panel.withOpacity(0.65),
                                  ],
                          ),
                          border: Border.all(
                            color: glow
                                ? sc
                                : col.withOpacity(_answered ? 0.15 : 0.32),
                            width: glow ? 1.8 : 1,
                          ),
                          boxShadow: glow
                              ? [
                                  BoxShadow(
                                    color: sc.withOpacity(0.4),
                                    blurRadius: 20,
                                  ),
                                ]
                              : [],
                        ),
                        child: Row(
                          children: [
                            Container(
                              width: 38,
                              height: 38,
                              decoration: BoxDecoration(
                                borderRadius: BorderRadius.circular(10),
                                gradient: LinearGradient(
                                  colors: glow
                                      ? [
                                          sc.withOpacity(0.5),
                                          sc.withOpacity(0.2),
                                        ]
                                      : [
                                          col.withOpacity(0.2),
                                          col.withOpacity(0.07),
                                        ],
                                ),
                                border: Border.all(
                                  color: glow ? sc : col.withOpacity(0.4),
                                ),
                              ),
                              alignment: Alignment.center,
                              child: Text(
                                letters[i],
                                style: TextStyle(
                                  fontWeight: FontWeight.w900,
                                  color: glow ? sc : col,
                                  fontSize: 14,
                                ),
                              ),
                            ),
                            const SizedBox(width: 12),
                            Expanded(
                              child: Text(
                                opts[i],
                                style: TextStyle(
                                  fontSize: 14,
                                  color: glow ? K.w100 : K.w80,
                                  height: 1.35,
                                ),
                              ),
                            ),
                          ],
                        ),
                      ),
                    ),
                  );
                }),
              ],
            ),
          ),
        ),
      ],
    );
  }
}

