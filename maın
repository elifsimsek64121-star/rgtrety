class GameScreen extends StatefulWidget {
  const GameScreen({super.key});
  @override
  State<GameScreen> createState() => _GameState();
}

class _GameState extends State<GameScreen> with TickerProviderStateMixin {
  int lvlIdx = 0, step = 0, selected = -1;
  bool answered = false, loading = true;
  int timeLeft = 30;
  Set<int> hidden = {};
  List<List<Map<String, dynamic>>> qs = [];
  int? correct;
  int _totalCorrect = 0;
  bool l50 = false,
      lAud = false,
      lPhone = false,
      lDip = false,
      lTime = false,
      lSwap = false;
  bool dipActive = false;
  int dipTries = 0;

  late final AnimationController _timerC =
      AnimationController(vsync: this, duration: const Duration(seconds: 30))
        ..addListener(_tick)
        ..addStatusListener(_timerDone);
  late final AnimationController _qC = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 520),
  );
  late final AnimationController _pulseC = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 900),
  )..repeat(reverse: true);
  late final AnimationController _flashC = AnimationController(
    vsync: this,
    duration: const Duration(milliseconds: 700),
  );
  late final AnimationController _ambientC = AnimationController(
    vsync: this,
    duration: const Duration(seconds: 6),
  )..repeat(reverse: true);

  late final Animation<double> _qFade = CurvedAnimation(
    parent: _qC,
    curve: Curves.easeIn,
  );
  late final Animation<Offset> _qSlide = Tween<Offset>(
    begin: const Offset(0, 0.07),
    end: Offset.zero,
  ).animate(CurvedAnimation(parent: _qC, curve: Curves.easeOutCubic));
  late final Animation<double> _timerPulse = Tween(
    begin: 0.9,
    end: 1.1,
  ).animate(CurvedAnimation(parent: _pulseC, curve: Curves.easeInOut));
  late final Animation<double> _flashOut = CurvedAnimation(
    parent: _flashC,
    curve: Curves.easeOut,
  );
  late final Animation<double> _ambient = Tween(
    begin: 0.6,
    end: 1.0,
  ).animate(CurvedAnimation(parent: _ambientC, curve: Curves.easeInOut));

  bool _timeUpDone = false, _timerRunning = false;
  BannerAd? _banner;
  bool _bannerLoaded = false;
  RewardedAd? _rewarded;
  InterstitialAd? _levelAd;
  bool _waitingLevel = false;
  final _sfx = AudioPlayer();

  Level get lvl => Level.all[lvlIdx];
  bool get highLevel => lvlIdx >= 1;
  int get total => lvl.count;
  String get prize => step < total ? lvl.prizes[step] : lvl.prizes.last;
  Color get _stageColor =>
      answered ? (selected == correct ? K.correct : K.wrong) : lvl.color;

  @override
  void initState() {
    super.initState();
    _loadBanner();
    _loadRewarded();
    _loadLevelAd();
    _loadQuestions();
  }

  @override
  void dispose() {
    _timerC.dispose();
    _qC.dispose();
    _pulseC.dispose();
    _flashC.dispose();
    _ambientC.dispose();
    _banner?.dispose();
    _rewarded?.dispose();
    _levelAd?.dispose();
    _sfx.dispose();
    super.dispose();
  }

  void _tick() {
    final n = 30 - (_timerC.lastElapsedDuration?.inSeconds ?? 0);
    if (n != timeLeft && mounted) setState(() => timeLeft = n.clamp(0, 30));
    if (!_timerRunning && SettingsService.sound) {
      _timerRunning = true;
      _sound('timer.mp3', loop: true);
    }
  }

  void _timerDone(AnimationStatus s) {
    if (s == AnimationStatus.completed && !_timeUpDone) {
      _timeUpDone = true;
      _stopSound();
      if (!answered) _reveal(timeout: true);
    }
  }

  void _startTimer([int sec = 30]) {
    _timerRunning = false;
    _timeUpDone = false;
    timeLeft = sec;
    _timerC.duration = Duration(seconds: sec);
    _timerC.forward(from: 0);
  }

  void _pauseTimer() {
    _timerC.stop();
    _stopSound();
    _timerRunning = false;
  }

  void _resumeTimer() {
    if (!mounted || answered) return;
    _timerRunning = false;
    _timeUpDone = false;
    _timerC.duration = Duration(seconds: timeLeft);
    _timerC.forward(from: 0);
  }

  Future<void> _sound(String f, {bool loop = false}) async {
    try {
      if (!SettingsService.sound) return;
      await _sfx.stop();
      await _sfx.setReleaseMode(loop ? ReleaseMode.loop : ReleaseMode.stop);
      await _sfx.setSource(AssetSource('sounds/$f'));
      await _sfx.resume();
    } catch (_) {}
  }

  void _stopSound() => _sfx.stop();

  void _loadBanner() {
    _banner = BannerAd(
      size: AdSize.banner,
      adUnitId: _AdConfig.banner,
      request: const AdRequest(),
      listener: BannerAdListener(
        onAdLoaded: (_) => setState(() => _bannerLoaded = true),
        onAdFailedToLoad: (ad, _) {
          ad.dispose();
          setState(() => _bannerLoaded = false);
          Future.delayed(const Duration(seconds: 12), _loadBanner);
        },
      ),
    )..load();
  }

  void _loadRewarded() {
    RewardedAd.load(
      adUnitId: _AdConfig.rewarded,
      request: const AdRequest(),
      rewardedAdLoadCallback: RewardedAdLoadCallback(
        onAdLoaded: (ad) => _rewarded = ad,
        onAdFailedToLoad: (_) {
          _rewarded = null;
          Future.delayed(const Duration(seconds: 8), _loadRewarded);
        },
      ),
    );
  }

  void _loadLevelAd() {
    InterstitialAd.load(
      adUnitId: _AdConfig.interstitial,
      request: const AdRequest(),
      adLoadCallback: InterstitialAdLoadCallback(
        onAdLoaded: (ad) => _levelAd = ad,
        onAdFailedToLoad: (_) {
          _levelAd = null;
          if (_waitingLevel && mounted) _doLevelTransition();
        },
      ),
    );
  }

  void _adForLifeline(String name, VoidCallback grant) {
    if (!highLevel) {
      grant();
      _snack('$name ✅', K.correct);
      return;
    }
    _pauseTimer();
    if (_rewarded != null) {
      _rewarded!.fullScreenContentCallback = FullScreenContentCallback(
        onAdDismissedFullScreenContent: (ad) {
          ad.dispose();
          _rewarded = null;
          _loadRewarded();
          _resumeTimer();
          grant();
          _snack('$name 🎉', K.correct);
        },
        onAdFailedToShowFullScreenContent: (ad, _) {
          ad.dispose();
          _rewarded = null;
          _fallbackAd(name, grant);
        },
      );
      _rewarded!.show(onUserEarnedReward: (_, __) {});
      _rewarded = null;
    } else
      _fallbackAd(name, grant);
  }

  void _fallbackAd(String name, VoidCallback grant) {
    InterstitialAd.load(
      adUnitId: _AdConfig.interstitial,
      request: const AdRequest(),
      adLoadCallback: InterstitialAdLoadCallback(
        onAdLoaded: (ad) {
          ad.fullScreenContentCallback = FullScreenContentCallback(
            onAdDismissedFullScreenContent: (a) {
              a.dispose();
              _resumeTimer();
              grant();
            },
            onAdFailedToShowFullScreenContent: (a, _) {
              a.dispose();
              _resumeTimer();
              grant();
            },
          );
          ad.show();
        },
        onAdFailedToLoad: (_) {
          _resumeTimer();
          grant();
        },
      ),
    );
  }

  Future<void> _loadQuestions() async {
    setState(() => loading = true);
    try {
      final raw =
          json.decode(await rootBundle.loadString('assets/questions.json'))
              as List;
      final all = raw.map((e) => Map<String, dynamic>.from(e)).toList()
        ..sort(
          (a, b) => (a['difficulty'] ?? 5).compareTo(b['difficulty'] ?? 5),
        );
      final easy = all.where((q) => (q['difficulty'] ?? 5) <= 3).toList()
        ..shuffle();
      final hard = all.where((q) => (q['difficulty'] ?? 5) > 3).toList()
        ..shuffle();
      final ordered = [...easy.take(10), ...hard, ...easy.skip(10)];
      qs = [];
      int i = 0;
      for (final lv in Level.all) {
        qs.add(ordered.skip(i).take(lv.count).toList());
        i += lv.count;
      }
      setState(() {
        loading = false;
        lvlIdx = 0;
        step = 0;
        correct = _ci(0, 0);
      });
      _qC.forward(from: 0);
      _startTimer();
    } catch (e) {
      setState(() => loading = false);
      _snack('${L10n.t('question_load_err')}: $e', K.wrong);
    }
  }

  int? _ci(int lv, int st) {
    if (lv >= qs.length || st >= qs[lv].length) return null;
    final q = qs[lv][st];
    final opts = (q['options'] as List?)?.cast<String>() ?? [];
    return opts.indexOf(q['correctAnswer']?.toString() ?? '');
  }

  String get _qText {
    if (qs.isEmpty || lvlIdx >= qs.length || step >= qs[lvlIdx].length)
      return '—';
    return qs[lvlIdx][step]['question']?.toString() ?? '—';
  }

  List<String> get _opts {
    if (qs.isEmpty || lvlIdx >= qs.length || step >= qs[lvlIdx].length)
      return [];
    return (qs[lvlIdx][step]['options'] as List?)?.cast<String>() ?? [];
  }

  void _reveal({bool timeout = false}) async {
    if (answered) return;
    _pauseTimer();
    if (timeout || selected == -1) {
      setState(() => answered = true);
      _flashC.forward(from: 0);
      await _sound('wrong.mp3');
      Future.delayed(const Duration(milliseconds: 1800), _endGame);
      return;
    }
    if (selected == correct) {
      setState(() {
        answered = true;
        _totalCorrect++;
      });
      dipActive = false;
      dipTries = 0;
      _flashC.forward(from: 0);
      await _sound('correct.mp3');
      Future.delayed(const Duration(milliseconds: 1800), _nextQ);
    } else if (dipActive && dipTries < 1) {
      dipTries++;
      await _sound('wrong.mp3');
      setState(() {
        hidden.add(selected);
        selected = -1;
        answered = false;
      });
      Future.delayed(const Duration(milliseconds: 1000), () {
        if (!mounted) return;
        _snack(L10n.t('wrong_try'), K.blue);
        _resumeTimer();
      });
    } else {
      setState(() => answered = true);
      _flashC.forward(from: 0);
      await _sound('wrong.mp3');
      Future.delayed(const Duration(milliseconds: 1800), _endGame);
    }
  }

  void _nextQ() {
    if (step == total - 1) {
      lvlIdx < Level.all.length - 1
          ? _levelUp()
          : _showEnd(true, '${Level.all.last.prizes.last}');
      return;
    }
    setState(() {
      step++;
      selected = -1;
      answered = false;
      hidden.clear();
      correct = _ci(lvlIdx, step);
    });
    _qC.forward(from: 0);
    _startTimer();
  }

  void _levelUp() {
    _pauseTimer();
    setState(() => _waitingLevel = true);
    showDialog(
      context: context,
      barrierDismissible: false,
      builder: (_) => WillPopScope(
        onWillPop: () async => false,
        child: _LevelUpDialog(next: Level.all[lvlIdx + 1]),
      ),
    );
    if (_levelAd != null) {
      _levelAd!.fullScreenContentCallback = FullScreenContentCallback(
        onAdDismissedFullScreenContent: (ad) {
          ad.dispose();
          _levelAd = null;
          _loadLevelAd();
          if (mounted) _doLevelTransition();
        },
        onAdFailedToShowFullScreenContent: (ad, _) {
          ad.dispose();
          _levelAd = null;
          _loadLevelAd();
          if (mounted) _doLevelTransition();
        },
      );
      _levelAd!.show();
      _levelAd = null;
    } else
      Future.delayed(const Duration(milliseconds: 1200), () {
        if (mounted) _doLevelTransition();
      });
  }

  void _doLevelTransition() {
    if (!mounted) return;
    Navigator.pop(context);
    setState(() {
      lvlIdx++;
      step = 0;
      selected = -1;
      answered = false;
      hidden.clear();
      correct = _ci(lvlIdx, 0);
      _waitingLevel = false;
      l50 = lAud = lPhone = lDip = lTime = lSwap = false;
      dipActive = false;
      dipTries = 0;
    });
    _qC.forward(from: 0);
    _startTimer();
  }

  String _guarantee([int? s]) {
    final idx = s ?? step;
    final cp = lvl.checkpoints;
    for (int i = cp.length - 1; i >= 0; i--) {
      if (idx >= cp[i]) return lvl.prizes[cp[i]];
    }
    return lvlIdx > 0 ? Level.all[lvlIdx - 1].prizes.last : '0';
  }

  void _endGame() {
    _pauseTimer();
    final finalPrize = _guarantee(step);
    final xpGain = _totalCorrect * 20 + lvlIdx * 50;
    FirebaseService.updateStats(
      xpGain: xpGain,
      correctCount: _totalCorrect,
      bestPrize: finalPrize,
    );
    _showEnd(false, '${L10n.t('guaranteed_earn')}: $finalPrize');
  }

  void _giveUp() {
    _pauseTimer();
    final finalPrize = _guarantee(step > 0 ? step - 1 : 0);
    final xpGain = _totalCorrect * 20 + lvlIdx * 50;
    FirebaseService.updateStats(
      xpGain: xpGain,
      correctCount: _totalCorrect,
      bestPrize: finalPrize,
    );
    _showEnd(true, '${L10n.t('earn')}: $finalPrize');
  }

  void _reset() {
    _pauseTimer();
    setState(() {
      selected = -1;
      lvlIdx = 0;
      step = 0;
      answered = false;
      hidden.clear();
      correct = null;
      _timerRunning = false;
      loading = true;
      _totalCorrect = 0;
      l50 = lAud = lPhone = lDip = lTime = lSwap = false;
      dipActive = false;
      dipTries = 0;
    });
    _loadQuestions();
  }

  void _showEnd(bool win, String msg) => showDialog(
    context: context,
    barrierDismissible: false,
    builder: (_) => _EndDialog(
      win: win,
      msg: msg,
      onRetry: () {
        Navigator.pop(context);
        _reset();
      },
      onExit: () => Navigator.pop(context),
    ),
  );

  void _askLifeline(
    String name,
    String emoji,
    String desc,
    VoidCallback action,
  ) {
    if (answered) {
      _snack(L10n.t('cannot_use'), K.wrong);
      return;
    }
    showDialog(
      context: context,
      builder: (ctx) => _LifelineDialog(
        name: name,
        emoji: emoji,
        desc: desc,
        highLevel: highLevel,
        onConfirm: () {
          Navigator.pop(ctx);
          _adForLifeline(name, action);
        },
        onCancel: () => Navigator.pop(ctx),
      ),
    );
  }

  void _use50() {
    if (l50 || correct == null || answered) return;
    _askLifeline(L10n.t('lifeline_50'), '✂️', L10n.t('fifty_desc'), () {
      setState(() {
        l50 = true;
        hidden.clear();
        final w = List.generate(4, (i) => i).where((i) => i != correct).toList()
          ..shuffle();
        hidden.addAll(w.take(2));
      });
    });
  }

  void _useAud() {
    if (lAud || correct == null || answered) return;
    _askLifeline(L10n.t('lifeline_aud'), '👥', L10n.t('aud_desc'), () {
      setState(() => lAud = true);
      final r = Random();
      int cv = 55 + r.nextInt(36), rem = 100 - cv;
      final Map<String, int> v = {};
      const L = ['A', 'B', 'C', 'D'];
      final w = List.generate(
        4,
        (i) => i,
      ).where((i) => i != correct && !hidden.contains(i)).toList();
      for (int i = 0; i < w.length; i++) {
        final val = i == w.length - 1
            ? rem
            : (rem * (0.1 + r.nextDouble() * 0.4)).round().clamp(0, rem);
        v[L[w[i]]] = val;
        rem -= val;
      }
      v[L[correct!]] = cv;
      final sorted = v.entries.toList()
        ..sort((a, b) => L.indexOf(a.key).compareTo(L.indexOf(b.key)));
      showDialog(
        context: context,
        builder: (_) =>
            _AudienceDialog(votes: sorted, correctLabel: L[correct!]),
      );
    });
  }

  void _usePhone() {
    if (lPhone || correct == null || answered) return;
    _askLifeline(L10n.t('lifeline_phone'), '📞', L10n.t('phone_desc'), () {
      setState(() => lPhone = true);
      final r = Random();
      final opts = _opts;
      final avail = List.generate(
        4,
        (i) => i,
      ).where((i) => !hidden.contains(i) && i != correct).toList();
      final ans = r.nextInt(10) < 8
          ? opts[correct!]
          : (avail.isNotEmpty
                ? opts[avail[r.nextInt(avail.length)]]
                : opts[correct!]);
      final pct = 62 + r.nextInt(33);
      showDialog(
        context: context,
        builder: (_) => _PhoneDialog(answer: ans, confidence: pct),
      );
    });
  }

  void _useDip() {
    if (lDip || answered) return;
    if (step < lvl.checkpoints.last) {
      _snack(L10n.t('dip_locked'), Colors.orange);
      return;
    }
    _askLifeline(L10n.t('lifeline_dip'), '🎯', L10n.t('dip_desc'), () {
      setState(() {
        lDip = true;
        dipActive = true;
        dipTries = 0;
      });
    });
  }

  void _useTime() {
    if (lTime || answered) return;
    _askLifeline(L10n.t('lifeline_time'), '⏰', L10n.t('time_desc'), () {
      _pauseTimer();
      setState(() => lTime = true);
      Future.delayed(
        const Duration(milliseconds: 50),
        () => _startTimer((timeLeft + 15).clamp(0, 60)),
      );
    });
  }

  void _useSwap() {
    if (lSwap || answered) return;
    _askLifeline(L10n.t('lifeline_swap'), '🔄', L10n.t('swap_desc'), () {
      if (qs[lvlIdx].length > step + 1) {
        setState(() {
          lSwap = true;
          final rm = qs[lvlIdx].removeAt(step);
          qs[lvlIdx].add(rm);
          selected = -1;
          answered = false;
          hidden.clear();
          correct = _ci(lvlIdx, step);
        });
        _qC.forward(from: 0);
        _startTimer();
      } else
        _snack(L10n.t('no_swap'), Colors.orange);
    });
  }

  void _snack(String msg, Color color) {
    if (!mounted) return;
    ScaffoldMessenger.of(context).clearSnackBars();
    ScaffoldMessenger.of(context).showSnackBar(
      SnackBar(
        content: Text(msg, style: const TextStyle(fontWeight: FontWeight.w700)),
        backgroundColor: color,
        behavior: SnackBarBehavior.floating,
        shape: RoundedRectangleBorder(borderRadius: BorderRadius.circular(14)),
        margin: const EdgeInsets.all(14),
      ),
    );
  }

