// ═══════════════════════════════════════════════════════════════════
class DuelLobbyScreen extends StatefulWidget {
  final VoidCallback onRefreshProfile;
  const DuelLobbyScreen({super.key, required this.onRefreshProfile});
  @override
  State<DuelLobbyScreen> createState() => _DuelLobbyScreenState();
}

class _DuelLobbyScreenState extends State<DuelLobbyScreen> {
  List<Map<String, dynamic>> _openDuels = [];
  bool _loading = false;
  @override
  void initState() {
    super.initState();
    _load();
  }

  Future<void> _load() async {
    setState(() => _loading = true);
    final duels = await FirebaseService.findOpenDuels();
    if (mounted)
      setState(() {
        _openDuels = duels;
        _loading = false;
      });
  }

  Future<void> _createDuel() async {
    final profile = await FirebaseService.getProfile();
    if (profile == null || !mounted) return;
    final id = await FirebaseService.createDuel(profile);
    if (!mounted) return;
    Navigator.push(
      context,
      MaterialPageRoute(
        builder: (_) =>
            DuelWaitingScreen(duelId: id, isHost: true, profile: profile),
      ),
    ).then((_) {
      _load();
      widget.onRefreshProfile();
    });
  }

  Future<void> _joinDuel(String duelId) async {
    final profile = await FirebaseService.getProfile();
    if (profile == null || !mounted) return;
    final ok = await FirebaseService.joinDuel(duelId, profile);
    if (!mounted) return;
    if (ok) {
      Navigator.push(
        context,
        MaterialPageRoute(
          builder: (_) => DuelWaitingScreen(
            duelId: duelId,
            isHost: false,
            profile: profile,
          ),
        ),
      ).then((_) {
        _load();
        widget.onRefreshProfile();
      });
    } else {
      ScaffoldMessenger.of(context).showSnackBar(
        SnackBar(
          content: Text(L10n.t('join_failed')),
          backgroundColor: K.wrong,
        ),
      );
    }
  }

  @override
  Widget build(BuildContext context) => RefreshIndicator(
    onRefresh: _load,
    color: K.gold2,
    child: ListView(
      padding: const EdgeInsets.all(16),
      children: [
        const SizedBox(height: 8),
        ShaderMask(
          shaderCallback: (b) =>
              const LinearGradient(colors: [K.violet, K.cyan]).createShader(b),
          child: Text(
            L10n.t('live_duel'),
            textAlign: TextAlign.center,
