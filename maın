class _AuthScreenState extends State<AuthScreen> with TickerProviderStateMixin {
  bool _isRegister = false, _loading = false, _showEmail = false;
  final _email = TextEditingController();
  final _pass = TextEditingController();
  final _name = TextEditingController();
  String? _error;

  late final AnimationController _ambient = AnimationController(
    vsync: this,
    duration: const Duration(seconds: 3),
  )..repeat(reverse: true);
  late final Animation<double> _glow = Tween(
    begin: 0.5,
    end: 1.0,
  ).animate(CurvedAnimation(parent: _ambient, curve: Curves.easeInOut));

  @override
  void dispose() {
    _ambient.dispose();
    _email.dispose();
    _pass.dispose();
    _name.dispose();
    super.dispose();
  }

  Future<void> _doGoogle() async {
    setState(() {
      _loading = true;
      _error = null;
    });
    final u = await FirebaseService.signInWithGoogle();
    if (!mounted) return;
    if (u == null)
      setState(() {
        _loading = false;
        _error = L10n.t('google_failed');
      });
    else
      setState(() => _loading = false);
  }

  Future<void> _doFacebook() async {
    setState(() {
      _loading = true;
      _error = null;
    });
    final u = await FirebaseService.signInWithFacebook();
    if (!mounted) return;
    if (u == null)
      setState(() {
        _loading = false;
        _error = L10n.t('facebook_failed');
      });
    else
      setState(() => _loading = false);
  }

  Future<void> _doGuest() async {
    setState(() {
      _loading = true;
      _error = null;
    });
    final u = await FirebaseService.signInAsGuest();
    if (!mounted) return;
    if (u == null)
      setState(() {
        _loading = false;
        _error = 'Guest failed.';
      });
    else
      setState(() => _loading = false);
  }

  Future<void> _doEmail() async {
    if (_email.text.isEmpty || _pass.text.isEmpty) {
      setState(() => _error = L10n.t('email_required'));
      return;
    }
    setState(() {
      _loading = true;
      _error = null;
    });
    User? u;
    if (_isRegister) {
      if (_name.text.isEmpty) {
        setState(() {
          _loading = false;
          _error = L10n.t('name_required');
        });
        return;
      }
      u = await FirebaseService.registerWithEmail(
        _email.text.trim(),
        _pass.text.trim(),
        _name.text.trim(),
      );
    } else {
      u = await FirebaseService.signInWithEmail(
        _email.text.trim(),
        _pass.text.trim(),
      );
    }
    if (!mounted) return;
    if (u == null)
      setState(() {
        _loading = false;
        _error = _isRegister
            ? L10n.t('register_failed')
            : L10n.t('login_failed');
      });
    else
      setState(() => _loading = false);
  }

