//  AI QUESTION SERVICE
// ═══════════════════════════════════════════════════════════════════
class AIQuestionService {
  static Future<List<Map<String, dynamic>>> generateQuestions({
    int count = 5,
    String difficulty = 'medium',
    String topic = 'general knowledge',
  }) async {
    try {
      final lang = L10n.lang == 'tr' ? 'Türkçe' : 'English';
      final prompt =
          '$lang dilinde bir bilgi yarışması için $count adet $difficulty zorlukta $topic konulu soru üret.\nSadece JSON array döndür, başka metin ekleme:\n[\n  {\n    "question": "soru",\n    "options": ["A","B","C","D"],\n    "correctAnswer": "doğru şık",\n    "difficulty": 3,\n    "topic": "$topic"\n  }\n]';
      final resp = await http
          .post(
            Uri.parse('https://api.anthropic.com/v1/messages'),
            headers: {
              'Content-Type': 'application/json',
              'x-api-key': _ApiConfig.key,
              'anthropic-version': '2023-06-01',
            },
            body: jsonEncode({
              'model': _ApiConfig.model,
              'max_tokens': 2000,
              'messages': [
                {'role': 'user', 'content': prompt},
              ],
            }),
          )
          .timeout(const Duration(seconds: 30));
      if (resp.statusCode == 200) {
        final data = jsonDecode(resp.body);
        final text =
            (data['content'] as List).firstWhere(
                  (c) => c['type'] == 'text',
                  orElse: () => {'text': '[]'},
                )['text']
                as String;
        final clean = text
            .replaceAll('```json', '')
            .replaceAll('```', '')
            .trim();
        final qs = jsonDecode(clean) as List;
        if (FirebaseService.uid != null) {
          await FirebaseFirestore.instance
              .collection('users')
              .doc(FirebaseService.uid!)
              .update({'aiQuestionsGenerated': FieldValue.increment(count)});
        }
        return qs.cast<Map<String, dynamic>>();
      }
    } catch (e) {
      debugPrint('AI question: $e');
    }
    return [];
  }
}

