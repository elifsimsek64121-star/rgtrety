  Widget _buildOption(int i) {
    const letters = ['A', 'B', 'C', 'D'];
    final optCol = K.opts[i];
    if (hidden.contains(i))
      return Padding(
        padding: const EdgeInsets.only(bottom: 10),
        child: Container(
          height: 58,
          decoration: BoxDecoration(
            borderRadius: BorderRadius.circular(16),
            color: K.w05,
            border: Border.all(color: K.w10, width: 0.5),
          ),
        ),
      );
    final isSel = selected == i;
    final isCorr = correct == i;
    Color sc = optCol;
    bool glow = false;
    if (answered) {
      if (isCorr) {
        sc = K.correct;
        glow = true;
      } else if (isSel) {
        sc = K.wrong;
        glow = true;
      } else
        sc = optCol.withOpacity(0.3);
    } else if (isSel) {
      sc = K.select;
      glow = true;
    }
    return Padding(
      padding: const EdgeInsets.only(bottom: 10),
      child: GestureDetector(
        onTap:
            (answered ||
                hidden.contains(i) ||
                (selected != -1 && (!dipActive || dipTries >= 1)))
            ? null
            : () {
                setState(() => selected = i);
                Future.delayed(const Duration(milliseconds: 900), _reveal);
              },
        child: AnimatedContainer(
          duration: const Duration(milliseconds: 260),
          curve: Curves.easeOut,
          padding: const EdgeInsets.symmetric(horizontal: 14, vertical: 14),
          decoration: BoxDecoration(
            borderRadius: BorderRadius.circular(16),
            gradient: LinearGradient(
              begin: Alignment.centerLeft,
              end: Alignment.centerRight,
              colors: glow
                  ? [sc.withOpacity(0.28), sc.withOpacity(0.10)]
                  : [K.panelMid.withOpacity(0.75), K.panel.withOpacity(0.65)],
            ),
            border: Border.all(
              color: glow ? sc : optCol.withOpacity(answered ? 0.15 : 0.32),
              width: glow ? 1.8 : 1,
            ),
            boxShadow: glow
                ? [
                    BoxShadow(
                      color: sc.withOpacity(0.42),
                      blurRadius: 20,
                      spreadRadius: 1,
                    ),
                    BoxShadow(color: sc.withOpacity(0.15), blurRadius: 40),
                  ]
                : [],
          ),
          child: Row(
            children: [
              Container(
                width: 40,
                height: 40,
                decoration: BoxDecoration(
                  borderRadius: BorderRadius.circular(11),
                  gradient: LinearGradient(
                    begin: Alignment.topLeft,
                    end: Alignment.bottomRight,
                    colors: glow
                        ? [sc.withOpacity(0.50), sc.withOpacity(0.22)]
                        : [optCol.withOpacity(0.20), optCol.withOpacity(0.07)],
                  ),
                  border: Border.all(
                    color: glow
                        ? sc
                        : optCol.withOpacity(answered ? 0.15 : 0.40),
                    width: 1.2,
                  ),
                ),
                alignment: Alignment.center,
                child: Text(
                  letters[i],
                  style: TextStyle(
                    fontWeight: FontWeight.w900,
                    fontSize: 16,
                    color: glow
                        ? sc
                        : optCol.withOpacity(answered ? 0.3 : 0.85),
                  ),
                ),
              ),
              const SizedBox(width: 13),
              Expanded(
                child: Text(
                  _opts[i],
                  style: TextStyle(
                    fontSize: 15.5,
                    color: answered
                        ? (glow ? K.w100 : K.w40)
                        : (glow ? K.w100 : K.w80),
                    height: 1.35,
                    fontWeight: glow ? FontWeight.w600 : FontWeight.w400,
                  ),
                ),
              ),
              if (answered && isCorr)
                Container(
                  width: 28,
                  height: 28,
                  decoration: BoxDecoration(
                    shape: BoxShape.circle,
                    color: K.correct.withOpacity(0.18),
                    border: Border.all(color: K.correct, width: 1.5),
                  ),
                  child: const Icon(
                    Icons.check_rounded,
                    color: K.correct,
                    size: 16,
                  ),
                ),
              if (answered && isSel && !isCorr)
                Container(
                  width: 28,
                  height: 28,
                  decoration: BoxDecoration(
                    shape: BoxShape.circle,
                    color: K.wrong.withOpacity(0.18),
                    border: Border.all(color: K.wrong, width: 1.5),
                  ),
                  child: const Icon(
                    Icons.close_rounded,
                    color: K.wrong,
                    size: 16,
                  ),
                ),
            ],
          ),
        ),
      ),
    );
  }

