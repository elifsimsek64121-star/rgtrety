  Widget _buildTimer() {
    final pct = timeLeft / 30.0;
    final col = timeLeft > 20
        ? K.correct
        : timeLeft > 10
        ? Colors.orange
        : K.wrong;
    return AnimatedBuilder(
      animation: _pulseC,
      builder: (_, __) => Transform.scale(
        scale: timeLeft <= 10 ? _timerPulse.value : 1.0,
        child: SizedBox(
          width: 66,
          height: 66,
          child: Stack(
            alignment: Alignment.center,
            children: [
              if (timeLeft <= 10)
                Container(
                  width: 66,
                  height: 66,
                  decoration: BoxDecoration(
                    shape: BoxShape.circle,
                    boxShadow: [
                      BoxShadow(
                        color: col.withOpacity(0.45 * _timerPulse.value),
                        blurRadius: 22,
                        spreadRadius: 5,
                      ),
                    ],
                  ),
                ),
              CircularProgressIndicator(
                value: pct,
                color: col,
                backgroundColor: K.w10,
                strokeWidth: 4,
              ),
              Container(
                width: 52,
                height: 52,
                decoration: BoxDecoration(
                  shape: BoxShape.circle,
                  gradient: RadialGradient(colors: [K.panelLight, K.panel]),
                  boxShadow: [
